{
  "description": "Gaming sound notifications via PeonPing (Warcraft, StarCraft, Portal...)",
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "CESP_EVENT=task.complete ${CLAUDE_PLUGIN_ROOT}/scripts/play.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "CESP_EVENT=input.required ${CLAUDE_PLUGIN_ROOT}/scripts/play.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
